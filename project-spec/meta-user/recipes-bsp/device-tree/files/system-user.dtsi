/include/ "system-conf.dtsi"

/ {
    reserved-memory {
        #address-cells = <2>;
        #size-cells = <2>;
        ranges;

        //rts capture data reserved
        reserved: buffer@0 {
            no-map;
            reg = <0x0 0x38000000 0x0 0x4000000>;
        };

        // log system and RACD reserved
        rmdom0domain: rmdom0domain@22000000 {
            reg = <0x0 0x22000000 0x0 0xE000000>; // 224M
            no-map;
        };
    };

    rmdom0: rmdom0 {
        #address-cells = <1>;
        #size-cells = <1>;
        compatible = "linux,rmdom";
        memory-domain = <&rmdom0domain>;
        ranges;

        logsys@1000 {
            compatible = "linux,rmdom-rmem";
            reg = <0x1000 0x7FFF000>; // 128M - 4K - 4K for log system //skip RMDOM header
        };

        racd@8000000 {
            compatible = "linux,rmdom-rmem";
            reg = <0x8000000 0x4FFF000>; // 80 MB - 4K for Retrospective Analysis Core Dump
        };

        ramoops@5000000 { //support pstore (Persistent store support enabled in kernel)
            compatible = "linux,rmdom-ramoops";
            reg = <0xD000000 0x1000000>;//16MB
            record-size = <0x10000>;
            console-size = <0x10000>;
            ftrace-size = <0x10000>;
            rmsg-size = <0x10000>;
        };
    };

    rts_mem@0x38000000 {
        compatible = "generic-uio";
        reg = <0x0 0x38000000 0x0 0x4000000>;
    };
};

&qspi {
    status = "okay";
    is-dual = <0>;
    num-cs = <1>;
    flash@0 {
        compatible ="jedec,spi-nor";
        reg = <0x0>;
        spi-tx-bus-width = <1>;
        spi-rx-bus-width = <4>;
        spi-max-frequency = <108000000>;
        #address-cells = <1>;
        #size-cells = <1>;
    };
};

&gem0 {
    status = "okay";
    phy-handle = <&phy0>;
    phy-mode = "sgmii";
    is-internal-pcspma = <0x1>;
    phy0: phy@1 {
        reg = <0x1>;
    };
};

&gem1 {
    status = "disabled";
};

&gem2 {
    status = "okay";
    phy-mode = "gmii";
    fixed-link {
        speed = <1000>;
        full-duplex;
    };
};

&gem3 {
    status = "okay";
    phy-mode = "gmii";
    fixed-link {
        speed = <1000>;
        full-duplex;
    };
};

&flash0 {
    partition@21 {
        label = "reserved3";
        reg = <0x01000000 0x01000000>;
    };
};

&spi0 {
    status = "okay";
    num-cs = <1>;
    u-boot,dm-pre-reloc;
    spidev@0 {
        compatible="rohm,dh2228fv";
        reg = <0>;
        spi-max-frequency = <5000000>;
    };
};

&axi_quad_spi_0 {
    status = "okay";
    spidev@0 {
        compatible="rohm,dh2228fv";
        reg = <0>;
        spi-max-frequency = <5000000>;
    };

    spidev@1 {
        compatible="rohm,dh2228fv";
        reg = <1>;
        spi-max-frequency = <5000000>;
    };

    spidev@2 {
        compatible="rohm,dh2228fv";
        reg = <2>;
        spi-max-frequency = <5000000>;
    };

    spidev@3 {
        compatible="rohm,dh2228fv";
        reg = <3>;
        spi-max-frequency = <5000000>;
    };

    spidev@4 {
        compatible="rohm,dh2228fv";
        reg = <4>;
        spi-max-frequency = <5000000>;
    };

    spidev@5 {
        compatible="rohm,dh2228fv";
        reg = <5>;
        spi-max-frequency = <5000000>;
    };

    spidev@6 {
        compatible="rohm,dh2228fv";
        reg = <6>;
        spi-max-frequency = <5000000>;
    };
};
*/
&sdhci0 {
        status = "okay";
        bus-width = <8>;
        non-removable;
        cap-mmc-highspeed;
        cap-sd-highspeed;
        disable-wp;
        no-1-8-v;
};

&amba_pl {
    fpga: fpga@a0000000 {
        compatible = "generic-uio";
        reg = <0x0 0xA0000000 0x0 0x20000000>;
    };

    dpd_0_USER: dpd_user@a4000000 {
        compatible = "generic-uio";
        reg = <0x0 0xa4000000 0x0 0x20000>;
    };
};
