+static int ytxxxx_soft_reset(struct phy_device *phydev)
+{
+    int ret, val;
+
+    val = ytphy_read_ext(phydev, 0xa001);
+    ytphy_write_ext(phydev, 0xa001, (val & ~0x8000));
+
+    ret = ytphy_write_ext(phydev, 0xa000, 0);
+
+    return ret;
+}
