diff --git a/drivers/misc/Kconfig b/drivers/misc/Kconfig
index 2146856547b5..a52236e6ad25 100644
--- a/drivers/misc/Kconfig
+++ b/drivers/misc/Kconfig
@@ -611,6 +611,14 @@ config RSMU
 	  and other networking timing functions. It is used by the synced software to
 	  manage the Synchronous Ethernet (SyncE) device.
 
+config RMDOM
+        bool "Remaining Memory Domains"
+        default n
+        help
+          This driver manages domains of remaining memory after warm reboot, it's used
+          to create other drivers using persistent ram with dt. The main goal
+          is to be able to divide parts of SRAM of the layout as its reserved regions.
+
 source "drivers/misc/c2port/Kconfig"
 source "drivers/misc/eeprom/Kconfig"
 source "drivers/misc/cb710/Kconfig"
