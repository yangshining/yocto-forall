@@ -72,3 +72,4 @@ obj-$(CONFIG_TPS6594_PFSM)	+= tps6594-pfsm.o
 obj-$(CONFIG_XILINX_PUF)        += xilinx_puf.o
 rsmu-objs			:= rsmu_cdev.o rsmu_cm.o rsmu_sabre.o
 obj-$(CONFIG_RSMU)		+= rsmu.o
