diff --git a/drivers/misc/rmdom.c b/drivers/misc/rmdom.c
new file mode 100644
index 000000000000..39de4869b9f2
--- /dev/null
+++ b/drivers/misc/rmdom.c
@@ -0,0 +1,449 @@
+/*
+ * Remaining Memory Domains Header
+ * 
+ * set a separate domain/region into fs for log system after system reboot
+ */
+
+ #include <linux/platform_device.h>
+ #include <linux/io.h>
+ #include <linux/module.h>
+ 
+ #include <linux/pstore_ram.h>
+ #include <linux/slab.h>
+ 
+ #include <linux/of.h>
+ #include <linux/of_address.h>
+ 
+ #include <linux/crc32.h>
+ #include "rmdom.h"
+ 
+ // create rmdom unique ids
+ DEFINE_IDA(rmdom_uni_ida);
+ static const struct of_device_id rmdom_ids[] = {
+     { .compatible = "linux,rmdom", }, { },
+ };
+ 
+ // Init a resource for pmem from DT
+ static void populate_part_res(const struct rmdom_dev *rmddev, const struct rmdom_part *part, const char *name, struct resource *res)
+ {
+     res->name = name;
+     res->flags = IORESOURCE_MEM;
+     res->start = rmddev->start + part->start;
+     res->end = res->start + part->size - 1;
+     res->parent = res->sibling =  res->child = NULL;
+ }
+ 
+ // set ramoops private data by DT
+ static void populate_oops_pl_data(const struct rmdom_dev *rmddev, const struct rmdom_part *part, struct ramoops_platform_data *pdata)
+ {
+     const struct rmdom_ramoops *params = &part->params.ramoops;
+ 
+     pdata->mem_size     = part->size;
+     pdata->mem_type     = params->mem_type;
+     pdata->mem_address  = rmddev->start + part->start;
+     pdata->record_size  = params->record_size;
+     pdata->console_size = params->console_size;
+     pdata->pmsg_size    = params->rmsg_size;
+     pdata->ftrace_size  = params->ftrace_size;
+     pdata->ecc_info.ecc_size = (params->ecc_size == 1 ? 16 : params->ecc_size);
+     pdata->max_reason = KMSG_DUMP_OOPS;
+ }
+ 
+ // Helper function to read a size from a dtb
+ static u32 read_size_data(const struct device_node *node, const char *name)
+ {
+     u32 val = 0;
+     int ret;
+ 
+     ret = of_property_read_u32(node, name, &val);
+     if (ret < 0 && ret != -EINVAL) {
+         pr_err("Parse meta-data failed - %s: %d\n", name, ret);
+         return -1;
+     }
+     return val;
+ }
+ 
+ static void printout_hdr(struct rmdom_header *cfg_rh)
+ {
+     struct rmdom_header *rh = cfg_rh;
+     struct rmdom_part *part = &rh->parts[0];
+     int i;
+     printk("printout_hdr started - [mg:%x, v:%x.%x]\n", rh->magic, rh->major, rh->minor);
+     printk("printout_hdr checksum - [checksum:%x]\n", rh->cs);
+     for ( i = 0; i < 3; i++ )
+     {
+         printk("\tPart%x -- [categ:%x]\n", i, part->categ);
+         printk("\t ---- [part_sub_version:%x.%x]\n", part->major, part->minor);
+         printk("\t ---- [mem-reg:0x%x - 0x%x]\n", part->start, part->size);
+         part++;
+     }
+ }
+ 
+ static int register_nvdimm_bus(struct rmdom_dev *rmddev, struct device_node *dn)
+ {
+     int ret = 0;
+     dn = dev_of_node(rmddev->dev);
+     if (!dn) {
+         dev_err(rmddev->dev, "Node pointer empty\n");
+         ret = -ENODEV;
+         goto end;
+     }
+ 
+     rmddev->bus_desc.provider_name = "rmdom_rmem";
+     rmddev->bus_desc.module = THIS_MODULE;
+     rmddev->bus_desc.of_node = dn;
+ 
+     rmddev->bus = nvdimm_bus_register(rmddev->dev, &rmddev->bus_desc);
+     if (!rmddev->bus) {
+         dev_err(rmddev->dev, "Can't register nvdimm bus\n");
+         ret = -ENODEV;
+         goto end;
+     }
+ end:
+     return ret;
+ }
+ 
+ // Register devices as pointed by current header
+ static void register_subdevices(struct rmdom_dev *rmddev)
+ {
+     const struct rmdom_header *hdr = &rmddev->curr;
+     int i;
+     struct device_node *dnp;
+ 
+     //dev_info(rmddev->dev, "####reg subdevices config dump:\n");
+     //printout_hdr(hdr);
+     if(register_nvdimm_bus(rmddev, dnp)) {
+         dev_warn(rmddev->dev, "Failed to register nvdimm bus\n");
+         return;
+     }
+ 
+     // Register all known platform devices pointed by the header
+     dev_info(rmddev->dev, "current subdevices num %x\n", ARRAY_SIZE(hdr->parts)); 
+     for (i = 0; i < ARRAY_SIZE(hdr->parts); i++) {
+         const struct rmdom_part *part = &hdr->parts[i];
+         switch (part->categ) {
+         case RMDOM_CATEG_EMPTY:
+             break;
+         case RMDOM_CATEG_RMEM:
+         {
+             struct resource res;
+             struct nd_region_desc desc;
+             struct nd_region *region;
+ 
+             if (part->major != RMDOM_RMEM_MAJOR) {
+                 dev_info(rmddev->dev, "Query DT to get major version %d but expected %d for rmem in part %d\n", part->major, RMDOM_RMEM_MAJOR, i);
+                 continue;
+             }
+ 
+             populate_part_res(rmddev, part, "rmdom_rmem", &res);
+             dev_dbg(rmddev->dev, "rmem in slot %d in %p\n", i, &res);
+ 
+             memset(&desc, 0, sizeof(desc));
+             desc.numa_node = dev_to_node(rmddev->dev);
+             desc.res = &res;
+             desc.of_node = dnp;
+             set_bit(ND_REGION_PAGEMAP, &desc.flags);
+ 
+             region = nvdimm_pmem_region_create(rmddev->bus, &desc);
+ 
+             if (!region)
+                 dev_warn(rmddev->dev, "Can't register region %p with %p\n", desc.res, dnp);
+             else
+                 dev_dbg(rmddev->dev, "Registered region %p with %p\n", desc.res, dnp);
+             dev_info(rmddev->dev, "Register rmem device\n");
+             break;
+         }
+         case RMDOM_CATEG_RAMOOPS:
+         {
+             struct ramoops_platform_data pldata;
+             struct resource res;
+ 
+             if (!rmddev->pstore)
+                 continue;
+ 
+             if (part->major != RMDOM_RAMOOPS_MAJOR) {
+                 dev_info(rmddev->dev, "Query DT to get major version %d but expected %d for ramoops in part %d\n", part->major, RMDOM_RAMOOPS_MAJOR, i);
+                 continue;
+             }
+             populate_oops_pl_data(rmddev, part, &pldata);
+ 
+             res.start = pldata.mem_address;
+             res.end = res.start + pldata.mem_size + 1;
+             dev_dbg(rmddev->dev, "ramoops in slot %d %pR\n", i, &res);
+ 
+             rmddev->pdevs[i] = platform_device_register_data(NULL, "ramoops", -1, &pldata, sizeof(pldata));
+             if (IS_ERR(rmddev->pdevs[i])) {
+                 dev_warn(rmddev->dev, "Failed to register ramoops device in part %d with err=%ld\n", i, PTR_ERR(rmddev->pdevs[i]));
+             }
+             dev_info(rmddev->dev, "Register ramoops device\n");            
+             break;
+         }
+         default:
+             dev_warn(rmddev->dev, "Unexpected part %d\n", part->categ);
+             break;
+         }
+     }
+ }
+ 
+ // Deregister the subdevices registered
+ static int deregister_subdevices(struct rmdom_dev *rmddev)
+ {
+     int i;
+ 
+     if (rmddev->bus) {
+         nvdimm_bus_unregister(rmddev->bus);
+         rmddev->bus = NULL;
+     }
+ 
+     for (i = 0; i < RMDOM_PART_NUM; i++) {
+         struct platform_device *pdev = rmddev->pdevs[i];
+ 
+         if (!IS_ERR(pdev)) {
+             platform_device_unregister(pdev);
+         }
+         rmddev->pdevs[i] = NULL;
+     }
+     return 0;
+ }
+ 
+ //populate header with DT info
+ static int populate_hdr(struct rmdom_header *cfg_rh, struct platform_device *pdev)
+ {
+     int ret = 0;
+     struct rmdom_header *rh = cfg_rh;
+     struct rmdom_dev *rmddev = platform_get_drvdata(pdev);
+     struct rmdom_part *part = &rh->parts[0];
+     const struct device_node *of_node = pdev->dev.of_node;
+     struct device_node *subnode;
+ 
+     rmddev->pstore = false;
+     rh->magic = RMDOM_MAGIC;
+     rh->minor = RMDOM_MINOR;
+     rh->major = RMDOM_MAJOR;
+ 
+     for_each_child_of_node(of_node, subnode) {
+         struct resource res;
+         if (of_address_to_resource(subnode, 0, &res)) {
+             dev_warn(&pdev->dev, "Can't get resource for subnode %s\n", subnode->full_name);
+             continue;
+         }
+         part->start = res.start;
+         part->size = resource_size(&res);
+         dev_info(&pdev->dev, "Detect a part range: 0x%x : 0x%x\n", part->start, part->size);
+         if (of_device_is_compatible(subnode, "linux,rmdom-rmem")) {
+             part->categ = RMDOM_CATEG_RMEM;
+             part->major = RMDOM_RMEM_MAJOR;
+             part->minor = RMDOM_RMEM_MINOR;
+             part++;
+             dev_info(&pdev->dev, "A regular part\n");
+         } else if (of_device_is_compatible(subnode, "linux,rmdom-ramoops")) {
+             struct rmdom_ramoops *p = &part->params.ramoops;
+ 
+             part->categ = RMDOM_CATEG_RAMOOPS;
+             part->major = RMDOM_RAMOOPS_MAJOR;
+             part->minor = RMDOM_RAMOOPS_MINOR;
+ 
+             p->mem_type = of_property_read_bool(subnode, "unbuffered");
+             p->dump_oops = !of_property_read_bool(subnode, "no-dump-oops");
+ 
+             p->record_size = read_size_data(subnode, "record-size");
+             p->console_size = read_size_data(subnode, "console-size");
+             p->ftrace_size = read_size_data(subnode, "ftrace-size");
+             p->rmsg_size = read_size_data(subnode, "rmsg-size");
+             p->ecc_size = read_size_data(subnode, "ecc-size");
+             p->flags = read_size_data(subnode, "flags");
+             rmddev->pstore = true;
+             part++;
+             dev_info(&pdev->dev, "A ramoops part to enable pstore\n");
+         } else {
+             dev_warn(&pdev->dev, "Unexpected subnode node: %s\n", subnode->full_name);
+         }
+     }
+ 
+     rh->cs = crc32(0, rh, sizeof(struct rmdom_header));
+     return ret;
+ }
+ 
+ //alignment size to 1024bytes
+ static void header_def_sanity_check(void)
+ {
+     // check header's with the correct size
+     BUILD_BUG_ON(sizeof(struct rmdom_header) != RMDOM_HDR_SIZE);
+     BUILD_BUG_ON(sizeof(struct rmdom_part) != RMDOM_HDR_REGION_PADDING_SIZE);
+     BUILD_BUG_ON(offsetof(struct rmdom_header, parts) != RMDOM_HDR_REGION_PADDING_SIZE);
+ }
+ 
+ //get reserved memory range and mmap
+ static int rmdom_memmap(struct platform_device *pdev)
+ {
+     struct device_node *memdom;
+     struct device_node *of_node = pdev->dev.of_node;
+     struct rmdom_dev *rmddev = platform_get_drvdata(pdev);
+     struct resource res;
+     int ret = 0;
+     /* Map the persistent memory and copy out the header*/
+     memdom = of_parse_phandle(of_node, "memory-domain", 0);
+     if (!memdom) {
+         dev_err(&pdev->dev, "Not set memory-domain: %s\n", of_node->full_name);
+         ret = -ENODEV;
+         goto end;
+     }
+     ret = of_address_to_resource(memdom, 0, &res);
+     if (ret) {
+         dev_err(&pdev->dev, "Memory resource incorrect: %s\n", memdom->full_name);
+         goto end;
+     }
+ 
+     rmddev->start = res.start;
+     rmddev->size = resource_size(&res);
+     rmddev->virt = ioremap(rmddev->start, rmddev->size);
+     dev_info(&pdev->dev, "Reserved memory region range: 0x%x : 0x%x - virt %x\n", 
+         rmddev->start, rmddev->size, rmddev->virt);
+     if (!rmddev->virt) {
+         ret = -ENOMEM;
+         goto end;
+     }
+ end:    
+     return ret;
+ }
+ 
+ static int rmdom_remove(struct platform_device *pdev)
+ {
+     int ret;
+     struct rmdom_dev *rmddev = platform_get_drvdata(pdev);
+ 
+     dev_info(&pdev->dev, "rmdom_remove called\n");
+     ret = deregister_subdevices(rmddev);
+     if (ret)
+         return ret;
+ 
+     //rmdom_release_sysfs(rmddev);
+     iounmap(rmddev->virt);
+     kfree(rmddev);
+     dev_info(&pdev->dev, "rmdom_remove exit\n");
+     ret = 0;
+     return ret;
+ }
+ 
+ static int rmdom_probe(struct platform_device *pdev)
+ {
+     struct device_node *of_node = pdev->dev.of_node;
+     struct device_node *memdom;
+     int valid_hdr = 1;
+     int ret = 0;
+     u32 cs;
+     struct rmdom_dev *rmddev;
+     struct rmdom_header *hdr;
+     struct rmdom_header cfg_hdr;
+     struct resource res;
+ 
+     //set zero for its init
+     memset(&cfg_hdr, 0, sizeof(cfg_hdr));
+     dev_info(&pdev->dev, "rmdom_probe called\n");
+     rmddev = kzalloc(sizeof(*rmddev), GFP_KERNEL);
+     if (!rmddev)  {
+         ret = -ENOMEM;
+         dev_info(&pdev->dev, "rmdom kzalloc failed\n");
+         return ret;
+     }
+ 
+     header_def_sanity_check();
+ 
+     rmddev->id = ida_simple_get(&rmdom_uni_ida, 0, 0, GFP_KERNEL);
+     rmddev->dev = &pdev->dev;
+     dev_info(&pdev->dev, "Get ida id %d\n", rmddev->id);
+     if (rmddev->id < 0)
+         goto err_free_dev;
+     
+     // attach private data to platform device
+     platform_set_drvdata(pdev, rmddev);
+     // Init the defaulted header with DT info
+     (void) populate_hdr(&cfg_hdr, pdev);
+     //dev_info(&pdev->dev, "####local data config dump:\n");
+     //printout_hdr(&cfg_hdr);
+     //get memory range from DT
+     if(rmdom_memmap(pdev)) {
+         goto err_free;
+     }
+ 
+     // Init the current header
+     hdr = &rmddev->curr;
+ 
+     // Read out current reserved region header
+     memcpy(hdr, rmddev->virt, sizeof(struct rmdom_header));
+     //dev_info(&pdev->dev, "@@@current RAM read-back config dump:\n");
+     //printout_hdr(hdr);
+     // compare the header info from RAM with the one by default
+     cs = hdr->cs;
+     hdr->cs = 0;
+ 
+     if (hdr->magic != RMDOM_MAGIC) {
+         dev_info(&pdev->dev, "No RMDOM header magic\n");
+         valid_hdr = 0;
+     } else if (cs != crc32(0, hdr, sizeof(struct rmdom_header))) {
+         dev_info(&pdev->dev, "Incorrect checksum [0x%x != 0x%x]\n", cs, crc32(0, hdr, sizeof(struct rmdom_header)));
+         valid_hdr = 0;
+     }
+     // set value back
+     hdr->cs = cs;
+ 
+ 
+     if (valid_hdr)
+         dev_info(&pdev->dev, "Detected correct RMDOM header with version %d.%d\n", hdr->major, hdr->minor);
+ 
+     // No correct header, create a default one from DT
+     if (!valid_hdr) {
+         memcpy(&rmddev->curr, &cfg_hdr, sizeof(rmddev->curr));
+         dev_info(&pdev->dev, "Using meta-data config from DT -- version %d.%d\n", hdr->major, hdr->minor);
+     }
+     //dev_info(&pdev->dev, "####current segment config dump:\n");
+     //printout_hdr(&rmddev->curr);
+ 
+     if (hdr->major != RMDOM_MAJOR) {
+         dev_err(&pdev->dev, "Found major version %d but expected %d for main header\n", hdr->major, RMDOM_MAJOR);
+     } else {
+         memcpy(rmddev->virt, &rmddev->curr, sizeof(rmddev->curr));
+         dev_info(&pdev->dev, "Set back to the header inside RAM.\n");
+         dev_info(&pdev->dev, "####virt segment config dump:\n");
+         printout_hdr((struct rmdom_header*)rmddev->virt); 
+         register_subdevices(rmddev);
+     }
+ 
+     dev_info(&pdev->dev, "rmdom_probe exit - no sysfs\n");
+     return 0;
+ 
+  err_free:
+     ida_simple_remove(&rmdom_uni_ida, rmddev->id);
+  err_free_dev:
+     kfree(rmddev);
+  err:
+     return ret;
+ }
+ 
+ MODULE_DEVICE_TABLE(of, rmdom_ids);
+ static struct platform_driver rmdom_pl_drv = {
+     .remove = rmdom_remove,    
+     .probe = rmdom_probe,
+     .driver = {
+         .of_match_table = rmdom_ids,
+         .name   = "rmdom",
+         .owner  = THIS_MODULE,
+     }
+ };
+ 
+ static void __exit rmdom_exit(void)
+ {
+     platform_driver_unregister(&rmdom_pl_drv);
+ }
+ 
+ static int __init rmdom_init(void)
+ {
+     return platform_driver_register(&rmdom_pl_drv);
+ }
+ 
+ module_exit(rmdom_exit);
+ fs_initcall(rmdom_init);
+ 
+ MODULE_LICENSE("GPL");
+ MODULE_AUTHOR("null.com");
+ 
\ No newline at end of file
diff --git a/drivers/misc/rmdom.h b/drivers/misc/rmdom.h
new file mode 100644
index 000000000000..8f3d989be040
--- /dev/null
+++ b/drivers/misc/rmdom.h
@@ -0,0 +1,81 @@
+/*
+ * Remaining Memory Domains Header
+ * 
+ * set a separate domain/region for log system/racd after system warm reboot
+ */
+#ifndef _RM_DOM_H_
+#define _RM_DOM_H_
+
+#include <linux/types.h>
+
+#include <linux/libnvdimm.h>
+
+// set magic field
+#define RMDOM_MAGIC 0xCA693737
+
+// header's major and minor version
+#define RMDOM_MAJOR 1
+#define RMDOM_MINOR 1
+
+// Remaining memory domain category definition
+#define RMDOM_CATEG_EMPTY    0
+#define RMDOM_CATEG_RMEM     1
+#define RMDOM_CATEG_RAMOOPS  2
+
+#define RMDOM_RMEM_MAJOR    1
+#define RMDOM_RMEM_MINOR    1
+struct rmdom_rmem {};
+
+#define RMDOM_RAMOOPS_MAJOR 1
+#define RMDOM_RAMOOPS_MINOR 1
+struct rmdom_ramoops {
+    u8 mem_type;
+    u8 dump_oops;
+    u8 reserved[2];
+    u32 record_size;
+    u32 console_size;
+    u32 ftrace_size;
+    u32 rmsg_size;
+    u32 ecc_size;
+    u32 flags;
+};
+
+#define RMDOM_HDR_SIZE 1024
+#define RMDOM_HDR_REGION_PADDING_SIZE 128
+#define RMDOM_PART_NUM  7
+
+// the header placed into the 1KB at the begining of RMDOM reserved memory
+struct rmdom_header {
+    u32 magic;
+    u16 major;
+    u16 minor;
+    u32 cs; //its CRC32 checksum value
+    u8 padding1[RMDOM_HDR_REGION_PADDING_SIZE - 3 * sizeof(u32)];
+    struct rmdom_part {
+        u32 categ;//one of category for rmemory management
+        u16 major;
+        u16 minor;
+        u64 start;
+        u64 size;
+        union {
+            u8 padding2[RMDOM_HDR_REGION_PADDING_SIZE - 2 * sizeof(u32) - 2 * sizeof(u64)];
+            struct rmdom_ramoops ramoops;
+            struct rmdom_rmem rmem;
+        } params;
+    } parts[RMDOM_PART_NUM];
+} __packed;
+
+struct rmdom_dev {
+    int id;
+    struct device *dev;
+    phys_addr_t start;
+    resource_size_t size;
+    char *virt;    
+    struct rmdom_header curr; //current configuration for RMDOM
+    struct platform_device *pdevs[RMDOM_PART_NUM];
+    bool pstore;
+    struct nvdimm_bus *bus;
+    struct nvdimm_bus_descriptor bus_desc;
+};
+
+#endif
