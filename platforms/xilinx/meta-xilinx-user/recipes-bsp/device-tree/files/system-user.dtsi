*/
};

&spi1 {
    status = "okay";
    num-cs = <1>;
    tpm@0 {
        compatible = "infineon,slb9670";
        #address-cells = <1>;
        #size-cells = <0>;
        spi-max-frequency = <20000000>;
        reg = <0>;
    };
};

&qspi {
    status = "okay";
    is-dual = <0>;
    num-cs = <1>;
    flash@0 {
        compatible ="jedec,spi-nor";
        reg = <0x0>;
        spi-tx-bus-width = <1>;
        spi-rx-bus-width = <4>;
        spi-max-frequency = <108000000>;
        #address-cells = <1>;
        #size-cells = <1>;
    };
};

&gem0 {
    status = "okay";
    phy-handle = <&phy0>;
    phy-mode = "sgmii";
    is-internal-pcspma = <0x1>;
    phy0: phy@1 {
        reg = <0x1>;
    };
};

&spi0 {
    status = "okay";
    num-cs = <1>;
    u-boot,dm-pre-reloc;
    phc@0 {
        compatible="idt,8a34000";
        reg = <0>;
        spi-max-frequency = <10000000>;
        reset-gpio = <&gpio 24 1>;//GPIO_ACTIVE_LOW
    };
};

&sdhci0 {
        status = "okay";
        bus-width = <8>;
        non-removable;
        cap-mmc-highspeed;
        cap-sd-highspeed;
        disable-wp;
        no-1-8-v;
};

&gpio_keys {
	/* will be enabled in overlay */
	status = "disabled";
};

&uart1 {
	rts-gpio = <361>;
	linux,rs485-enabled-at-boot-time;
	rs485-rts-delay = <0 20>;
};

&debug_bridge_0 {
	compatible = "xlnx,xvc";
	status = "okay";
};

&axi_intc_ku5p {
	compatible = "xlnx,intc-interlink";
	// will be enabled in overlay
	status = "disabled";
};

&axi_quad_spi_0 {
    status = "okay";
    spidev@0 {
        compatible="rohm,dh2228fv";
        reg = <0>;
        spi-max-frequency = <5000000>;
