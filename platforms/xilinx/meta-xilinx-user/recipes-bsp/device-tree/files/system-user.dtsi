/ {
    gpio_keys:alarm_keys@0 {
        compatible = "gpio-keys";
        label = "Interrupt collection";
    };

    reserved-memory {
        #address-cells = <2>;
        #size-cells = <2>;
        ranges;

        //rts capture data reserved
        reserved: buffer@0 {
            no-map;
            reg = <0x0 0x38000000 0x0 0x4000000>;
        };

		rmdom0domain: rmdom0domain@22000000 {
			reg = <0x0 0x22000000 0x0 0xE000000>; // 224MB conflict with bootscript loading at 0x20000000,shift it
			no-map;
		};		
    };
	
	rmdom0: rmdom0 {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "linux,rmdom";
		memory-domain = <&rmdom0domain>;
		ranges;

		logsys@1000 {
			compatible = "linux,rmdom-rmem";
			reg = <0x1000 0x7FFF000>; // 128M - 4K - 4K for log system //skip RMDOM header
		};

		racd@8000000 {
			compatible = "linux,rmdom-rmem";
			reg = <0x8000000 0x4FFF000>; // 80 MB - 4K for Retrospective Analysis Core Dump
		};
	};	

    rts_mem@38000000 {
        compatible = "generic-uio";
        reg = <0x0 0x38000000 0x0 0x4000000>;
    };

/*
    select_map: select-map {
        compatible = "selectmap,ku5p";
        status = "okay";
        reg = <0x0 0xff0a0048 0x0 0x20>;
        first_check_cfg_done = <0>;
