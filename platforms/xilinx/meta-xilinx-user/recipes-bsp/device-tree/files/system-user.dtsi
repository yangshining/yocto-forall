&amba_pl {
    fpga: fpga@a0000000 {
        compatible = "generic-uio";
        reg = <0x0 0xA0000000 0x0 0x20000000>;
    };

    dpd_0_USER: dpd_user@a4000000 {
        compatible = "generic-uio";
        reg = <0x0 0xa4000000 0x0 0x20000>;
    };
};

&dpd_0{
    compatible = "generic-uio";
    reg = <0x0 0xa8000000 0x0 0x4000000>;
};

&support_1588_2step_timer1588_subs_timer_1588_v2_0_0 {
   compatible = "xlnx,timer-1588-2.0";
   xlnx,period = <4000000>;
   pps_in_fifo = <&axi_fifo_mm_s_0>;
};

&support_1588_2step1_timer1588_subs_timer_1588_v2_0_0 {
   compatible = "xlnx,timer-1588-2.0";
   xlnx,period = <4000000>;
   status = "disabled";
};

&xxv_ethernet_0 {
       axistream-connected = <&axi_mcdma_0>;
       axistream-control-connected = <&axi_mcdma_0>;
       axififo-connected = <&support_1588_2step_tx_ts_fifo_axi_fifo_mm_s_0>;
       xlnx,rxtsfifo = <&support_1588_2step_rx_ts_fifo_axi_fifo_mm_s_0>;
       xlnx,num-queues = /bits/ 16 <0x1>;
       xlnx,channel-ids = "1";
       xlnx,include-dre;
       xlnx,rxmem = <0x3000>;
       interrupt-names = "mm2s_ch1_introut", "s2mm_ch1_introut";
       interrupt-parent = <&gic>;
       interrupts = <0 92 4 0 94 4>;
       local-mac-address = [00 0A 35 00 1A AE];
       phy-mode = "base-r";
       /delete-property/ managed;
};


&xxv_ethernet_1 {
       axistream-connected = <&axi_mcdma_0>;
       axistream-control-connected = <&axi_mcdma_0>;
       axififo-connected = <&support_1588_2step1_tx_ts_fifo_axi_fifo_mm_s_0>;
       xlnx,rxtsfifo = <&support_1588_2step1_rx_ts_fifo_axi_fifo_mm_s_0>;
       xlnx,num-queues = /bits/ 16 <0x1>;
       xlnx,channel-ids = "2";
       xlnx,include-dre;
       xlnx,rxmem = <0x3000>;
       interrupt-names = "mm2s_ch2_introut", "s2mm_ch2_introut";
       interrupt-parent = <&gic>;
       interrupts = <0 93 4 0 95 4>;
       local-mac-address = [00 0A 35 00 1A AF];
       phy-mode = "base-r";
       /delete-property/ managed;
};

&axi_mcdma_0 {
       compatible = "xlnx,eth-dma";
       xlnx,include-dre;
};
